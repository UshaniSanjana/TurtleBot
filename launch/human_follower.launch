

<?xml version="1.0"?>
<launch>
    <!-- Human Follower Node -->
    <node name="human_follower" pkg="turtlebot_human_follower" type="run_follower.py" output="screen">
        
        <!-- Load parameters from YAML -->
        <rosparam command="load" file="$(find turtlebot_human_follower)/config/params.yaml" />
        
        <!-- Camera topics (adjust if using different camera) -->
        <param name="color_topic" value="/camera/color/image_raw" />
        <param name="depth_topic" value="/camera/aligned_depth_to_color/image_raw" />
        
        <!-- Robot command topic -->
        <param name="cmd_vel_topic" value="/cmd_vel_mux/input/teleop" />
        
    </node>
    
    <!-- Optional: Launch RealSense camera if not already running -->
    <!-- <include file="$(find realsense2_camera)/launch/rs_camera.launch">
        <arg name="align_depth" value="true"/>
    </include> -->
    
</launch>
